{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "noEmit": true,
    "checkJs": true,
    "strict": false,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true
  },
  "include": ["app.js", "checker.js", "server.js", "types/**/*.d.ts"]
}
